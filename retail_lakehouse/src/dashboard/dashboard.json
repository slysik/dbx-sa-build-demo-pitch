            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {"fieldName": "txn_date",      "scale": {"type": "temporal"},     "displayName": "Date"},
                "y": {"fieldName": "total_revenue", "scale": {"type": "quantitative"}, "displayName": "Revenue ($)"}
              },
              "frame": {"showTitle": true, "title": "Daily Revenue ($) — 365 Days"}
            }
