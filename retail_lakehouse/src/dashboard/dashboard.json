{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS total_transactions, ",
        "  ROUND(SUM(total_revenue), 2) AS total_revenue, ",
        "  ROUND(AVG(avg_transaction_value), 2) AS avg_txn_value, ",
        "  SUM(total_units) AS total_units ",
        "FROM interview.retail.gold_sales_by_category"
      ]
    },
    {
      "name": "ds_category",
      "displayName": "Sales by Category",
      "queryLines": [
        "SELECT ",
        "  category, ",
        "  SUM(transaction_count) AS transactions, ",
        "  ROUND(SUM(total_revenue), 2) AS revenue, ",
        "  SUM(total_units) AS units ",
        "FROM interview.retail.gold_sales_by_category ",
        "GROUP BY category ",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "ds_region",
      "displayName": "Sales by Region",
      "queryLines": [
        "SELECT ",
        "  region, ",
        "  store_format, ",
        "  SUM(transaction_count) AS transactions, ",
        "  ROUND(SUM(total_revenue), 2) AS revenue ",
        "FROM interview.retail.gold_sales_by_store ",
        "GROUP BY region, store_format ",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "ds_daily",
      "displayName": "Daily Revenue Trend",
      "queryLines": [
        "SELECT ",
        "  transaction_date, ",
        "  daily_revenue, ",
        "  transaction_count, ",
        "  avg_basket_size, ",
        "  active_stores ",
        "FROM interview.retail.gold_daily_revenue ",
        "ORDER BY transaction_date"
      ]
    },
    {
      "name": "ds_payment",
      "displayName": "Payment Mix",
      "queryLines": [
        "SELECT ",
        "  transaction_date, ",
        "  credit_card_txns, ",
        "  digital_wallet_txns, ",
        "  transaction_count - credit_card_txns - digital_wallet_txns AS other_txns ",
        "FROM interview.retail.gold_daily_revenue ",
        "ORDER BY transaction_date"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Retail Analytics",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
