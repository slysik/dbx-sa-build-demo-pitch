{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary — 1 Row",
      "queryLines": [
        "SELECT",
        "  CAST(SUM(total_revenue) AS DECIMAL(15,2)) AS total_revenue,",
        "  SUM(txn_count)                            AS total_txns,",
        "  ROUND(AVG(avg_order_value), 2)            AS avg_order_value",
        "FROM workspace.retail.gold_sales_by_category"
      ]
    },
    {
      "name": "ds_category",
      "displayName": "Revenue by Category",
      "queryLines": [
        "SELECT",
        "  category,",
        "  SUM(total_revenue) AS revenue,",
        "  SUM(txn_count)     AS txns",
        "FROM workspace.retail.gold_sales_by_category",
        "GROUP BY category",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "ds_region_format",
      "displayName": "Revenue by Region & Format",
      "queryLines": [
        "SELECT",
        "  region,",
        "  store_format,",
        "  SUM(total_revenue) AS revenue,",
        "  SUM(txn_count)     AS txns",
        "FROM workspace.retail.gold_sales_by_store",
        "GROUP BY region, store_format",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "ds_daily",
      "displayName": "Daily Revenue Trend",
      "queryLines": [
        "SELECT txn_date, total_revenue, txn_count",
        "FROM workspace.retail.gold_daily_revenue",
        "ORDER BY txn_date"
      ]
    }
  ],
  "pages": [
    {
      "name": "sales-overview",
      "displayName": "🛒 Sales Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": ["## 🛒 Retail Sales Intelligence — Full Year 2025"]
            }
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {
              "lines": ["100K transactions · 200 products · 50 stores · Medallion Pipeline on Databricks · Bronze → Silver → Gold → AI/BI"]
            }
          },
          "position": {"x": 0, "y": 1, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-revenue",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "ds_kpi",
              "fields": [{"name": "total_revenue", "expression": "`total_revenue`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "total_revenue", "displayName": "Total Revenue ($)"}},
              "frame": {"showTitle": true, "title": "💰 Total Revenue ($)"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-txns",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "ds_kpi",
              "fields": [{"name": "total_txns", "expression": "`total_txns`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "total_txns", "displayName": "Total Transactions"}},
              "frame": {"showTitle": true, "title": "📊 Total Transactions"}
            }
          },
          "position": {"x": 2, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-aov",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "ds_kpi",
              "fields": [{"name": "avg_order_value", "expression": "`avg_order_value`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "avg_order_value", "displayName": "Avg Order Value ($)"}},
              "frame": {"showTitle": true, "title": "🎯 Avg Order Value ($)"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "section-trend",
            "multilineTextboxSpec": {
              "lines": ["### 📈 Daily Revenue Trend — Full Year 2025"]
            }
          },
          "position": {"x": 0, "y": 5, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "chart-daily-trend",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "ds_daily",
              "fields": [
