{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary — 1 Row",
      "queryLines": [
        "SELECT ",
        "  SUM(txn_count)                                              AS total_txns, ",
        "  ROUND(SUM(total_revenue), 0)                               AS total_volume, ",
        "  SUM(high_risk_count)                                       AS flagged_count, ",
        "  ROUND(SUM(high_risk_count) * 100.0 / SUM(txn_count), 2)   AS risk_rate_pct, ",
        "  ROUND(AVG(avg_risk_score), 1)                              AS avg_risk_score, ",
        "  SUM(CASE WHEN txn_status = 'Approved' THEN txn_count ELSE 0 END) AS approved_txns ",
        "FROM workspace.finserv.gold_txn_by_category"
      ]
    },
    {
      "name": "ds_daily_trend",
      "displayName": "Daily Volume & Risk Trend",
      "queryLines": [
        "SELECT ",
        "  txn_date, ",
        "  SUM(total_txns)                                              AS total_txns, ",
        "  SUM(high_risk_count)                                        AS high_risk_count, ",
        "  ROUND(SUM(total_volume), 0)                                 AS daily_volume ",
        "FROM workspace.finserv.gold_daily_risk ",
        "GROUP BY txn_date ",
        "ORDER BY txn_date"
      ]
    },
    {
      "name": "ds_monthly_category",
      "displayName": "Monthly Revenue by Merchant Category",
      "queryLines": [
        "SELECT ",
        "  merchant_category, ",
        "  txn_month, ",
        "  SUM(txn_count)              AS txn_count, ",
        "  ROUND(SUM(total_revenue), 0) AS revenue ",
        "FROM workspace.finserv.gold_txn_by_category ",
        "WHERE txn_status = 'Approved' ",
        "  AND merchant_category != 'Other' ",
        "GROUP BY merchant_category, txn_month ",
        "ORDER BY txn_month, revenue DESC"
      ]
    },
    {
      "name": "ds_category_summary",
      "displayName": "Category Revenue & Risk",
      "queryLines": [
        "SELECT ",
        "  merchant_category, ",
        "  SUM(txn_count)                                            AS txn_count, ",
        "  ROUND(SUM(total_revenue), 0)                             AS revenue, ",
        "  ROUND(SUM(high_risk_count) * 100.0 / SUM(txn_count), 2) AS risk_rate_pct ",
        "FROM workspace.finserv.gold_txn_by_category ",
        "WHERE merchant_category != 'Other' ",
        "GROUP BY merchant_category ",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "ds_txn_status",
      "displayName": "Transaction Status Distribution",
      "queryLines": [
        "SELECT ",
        "  txn_status, ",
        "  SUM(txn_count)               AS txn_count, ",
        "  ROUND(SUM(total_revenue), 0) AS revenue, ",
        "  ROUND(AVG(avg_risk_score), 1) AS avg_risk_score ",
        "FROM workspace.finserv.gold_txn_by_category ",
        "GROUP BY txn_status ",
        "ORDER BY txn_count DESC"
      ]
    },
    {
      "name": "ds_segment_risk",
      "displayName": "Segment × Risk Tier Matrix",
      "queryLines": [
        "SELECT ",
        "  segment, ",
        "  risk_tier, ",
        "  SUM(unique_customers)        AS customers, ",
        "  SUM(txn_count)               AS txn_count, ",
        "  ROUND(SUM(total_volume), 0)  AS volume, ",
        "  SUM(high_risk_txns)          AS high_risk, ",
        "  ROUND(AVG(risk_rate_pct), 2) AS risk_rate_pct ",
        "FROM workspace.finserv.gold_segment_risk ",
        "GROUP BY segment, risk_tier ",
        "ORDER BY volume DESC"
      ]
    },
    {
      "name": "ds_region",
      "displayName": "Regional Performance",
      "queryLines": [
        "SELECT ",
        "  region, ",
        "  SUM(total_txns)                                              AS txn_count, ",
        "  ROUND(SUM(total_volume), 0)                                  AS volume, ",
        "  ROUND(SUM(high_risk_count) * 100.0 / SUM(total_txns), 2)    AS risk_rate_pct ",
        "FROM workspace.finserv.gold_daily_risk ",
        "GROUP BY region ",
        "ORDER BY volume DESC"
      ]
    },
    {
      "name": "ds_account_type",
      "displayName": "Account Type Revenue Split",
      "queryLines": [
        "SELECT ",
        "  account_type, ",
        "  SUM(unique_accounts)         AS accounts, ",
        "  SUM(txn_count)               AS txn_count, ",
        "  ROUND(SUM(total_volume), 0)  AS volume, ",
        "  ROUND(AVG(avg_txn_amount), 2) AS avg_txn_amount ",
        "FROM workspace.finserv.gold_segment_risk ",
        "GROUP BY account_type ",
        "ORDER BY volume DESC"
      ]
    },
    {
      "name": "ds_segment_detail",
      "displayName": "Segment Performance Table",
      "queryLines": [
        "SELECT ",
        "  segment, ",
        "  SUM(unique_customers)        AS customers, ",
        "  SUM(unique_accounts)         AS accounts, ",
        "  SUM(txn_count)               AS txn_count, ",
        "  ROUND(SUM(total_volume), 0)  AS total_volume, ",
        "  ROUND(AVG(avg_txn_amount), 2) AS avg_txn_amount, ",
        "  SUM(high_risk_txns)          AS high_risk_txns, ",
        "  ROUND(AVG(risk_rate_pct), 2) AS risk_rate_pct, ",
        "  SUM(flagged_txns)            AS flagged_txns, ",
        "  SUM(declined_txns)           AS declined_txns ",
        "FROM workspace.finserv.gold_segment_risk ",
        "GROUP BY segment ",
        "ORDER BY total_volume DESC"
      ]
    }
  ],
