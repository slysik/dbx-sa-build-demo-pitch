{
  "datasets": [
    {
      "name": "kpi_summary",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT SUM(total_revenue) AS total_revenue, ",
        "SUM(order_count) AS total_orders, ",
        "SUM(unique_customers) AS total_customers, ",
        "ROUND(SUM(total_revenue) / SUM(order_count), 2) AS avg_order_value ",
        "FROM interview.retail.gold_daily_sales"
      ]
    },
    {
      "name": "daily_trend",
      "displayName": "Daily Revenue Trend",
      "queryLines": [
        "SELECT order_date, channel, ",
        "SUM(total_revenue) AS revenue, ",
        "SUM(order_count) AS orders ",
        "FROM interview.retail.gold_daily_sales ",
        "GROUP BY order_date, channel ",
        "ORDER BY order_date"
      ]
    },
    {
      "name": "category_perf",
      "displayName": "Category Performance",
      "queryLines": [
        "SELECT category, ",
        "SUM(total_revenue) AS revenue, ",
        "SUM(total_units_sold) AS units, ",
        "ROUND(AVG(margin_pct), 1) AS avg_margin_pct ",
        "FROM interview.retail.gold_product_performance ",
        "GROUP BY category ORDER BY revenue DESC"
      ]
    },
    {
      "name": "regional",
      "displayName": "Regional Summary",
      "queryLines": [
        "SELECT region, ",
        "SUM(total_revenue) AS revenue, ",
        "SUM(order_count) AS orders, ",
        "SUM(active_customers) AS customers ",
        "FROM interview.retail.gold_regional_summary ",
        "GROUP BY region ORDER BY revenue DESC"
      ]
    },
    {
      "name": "tier_ltv",
      "displayName": "Customer Tier LTV",
      "queryLines": [
        "SELECT loyalty_tier, ",
        "COUNT(*) AS customers, ",
        "ROUND(AVG(total_spend), 2) AS avg_spend, ",
        "ROUND(AVG(total_orders), 1) AS avg_orders, ",
        "ROUND(AVG(days_since_last_order), 0) AS avg_recency_days ",
        "FROM interview.retail.gold_customer_ltv ",
        "GROUP BY loyalty_tier ORDER BY avg_spend DESC"
      ]
    },
    {
      "name": "top_products",
      "displayName": "Top Products",
      "queryLines": [
        "SELECT product_name, category, total_revenue, ",
        "total_units_sold, margin_pct ",
        "FROM interview.retail.gold_product_performance ",
        "ORDER BY total_revenue DESC LIMIT 15"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Retail Performance Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": ["## 🛍️ Retail Performance Dashboard"]
            }
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {
              "lines": ["Medallion architecture: Bronze → Silver → Gold | 1M+ orders across 6 months"]
            }
          },
          "position": {"x": 0, "y": 1, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-revenue",
            "queries": [{"name": "main_query", "query": {
              "datasetName": "kpi_summary",
              "fields": [{"name": "total_revenue", "expression": "`total_revenue`"}],
              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_revenue", "displayName": "Total Revenue"}
              },
              "frame": {"showTitle": true, "title": "💰 Total Revenue"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-orders",
            "queries": [{"name": "main_query", "query": {
