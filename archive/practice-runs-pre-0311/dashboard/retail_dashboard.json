              "disaggregated": true
            }}],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_orders", "displayName": "Total Orders"}
              },
              "frame": {"showTitle": true, "title": "📦 Total Orders"}
            }
          },
          "position": {"x": 2, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-aov",
