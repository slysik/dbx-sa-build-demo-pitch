{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS total_txns, ",
        "  ROUND(SUM(amount), 2) AS total_amount, ",
        "  ROUND(AVG(amount), 2) AS avg_amount ",
        "FROM interview.payments.bronze_payment_transactions"
      ]
    },
    {
      "name": "ds_status",
      "displayName": "Status Distribution",
      "queryLines": [
        "SELECT status, COUNT(*) AS txn_count, ",
        "  ROUND(SUM(amount), 2) AS total_amount ",
        "FROM interview.payments.bronze_payment_transactions ",
        "GROUP BY status ",
        "ORDER BY txn_count DESC"
      ]
    },
    {
      "name": "ds_currency",
      "displayName": "Currency Distribution",
      "queryLines": [
        "SELECT currency, COUNT(*) AS txn_count, ",
        "  ROUND(SUM(amount), 2) AS total_amount ",
        "FROM interview.payments.bronze_payment_transactions ",
        "GROUP BY currency ",
        "ORDER BY txn_count DESC"
      ]
    },
    {
      "name": "ds_monthly",
      "displayName": "Monthly Trend",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', transaction_ts) AS txn_month, ",
        "  COUNT(*) AS txn_count, ",
        "  ROUND(SUM(amount), 2) AS total_amount ",
        "FROM interview.payments.bronze_payment_transactions ",
        "GROUP BY txn_month ",
        "ORDER BY txn_month"
      ]
    },
    {
      "name": "ds_skew",
      "displayName": "Top Payment Types (Skew)",
      "queryLines": [
        "SELECT ",
        "  COALESCE(p.type_name, 'unknown') AS type_name, ",
        "  COALESCE(p.processor, 'unknown') AS processor, ",
        "  CONCAT(COALESCE(p.type_name, 'unknown'), ' / ', COALESCE(p.processor, 'unknown')) AS type_processor, ",
        "  COUNT(*) AS txn_count, ",
        "  ROUND(COUNT(*) / 1000000.0, 2) AS txn_count_m, ",
        "  ROUND(SUM(t.amount), 2) AS total_amount ",
        "FROM interview.payments.bronze_payment_transactions t ",
        "LEFT JOIN interview.payments.bronze_payment_types p ",
        "  ON t.payment_type_id = p.payment_type_id ",
        "GROUP BY p.type_name, p.processor ",
        "ORDER BY txn_count DESC ",
        "LIMIT 10"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Payment Transactions — Bronze Analytics",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": ["## Payment Transactions — Bronze Analytics"]
            }
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {
              "lines": ["100M transactions | 10K payment types | 40% skew on ACH/PayPal | Hash-based deterministic generation"]
            }
          },
          "position": {"x": 0, "y": 1, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-total-txns",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "ds_kpi",
                "fields": [{"name": "total_txns", "expression": "`total_txns`"}],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_txns", "displayName": "Total Transactions"}
              },
              "frame": {"showTitle": true, "title": "Total Transactions"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 3}
