          },
          "position": {"x": 0, "y": 6, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "section-breakdown",
            "multilineTextboxSpec": {
              "lines": ["### Content & Engagement Breakdown"]
            }
