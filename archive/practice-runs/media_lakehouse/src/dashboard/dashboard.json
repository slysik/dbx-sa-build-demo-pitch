            }],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "stream_date",
                  "scale": {"type": "temporal"},
                  "displayName": "Date"
                },
                "y": {
                  "scale": {"type": "quantitative"},
                  "fields": [
                    {"fieldName": "total_streams", "displayName": "Streams"},
                    {"fieldName": "unique_viewers", "displayName": "Unique Viewers"}
                  ]
                }
              },
              "frame": {"showTitle": true, "title": "Daily Streams & Viewers"}
