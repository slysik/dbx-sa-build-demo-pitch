                  {"name": "genre", "expression": "`genre`"},
                  {"name": "total_streams", "expression": "`total_streams`"},
                  {"name": "total_watch_minutes", "expression": "`total_watch_minutes`"},
                  {"name": "avg_session_minutes", "expression": "`avg_session_minutes`"}
