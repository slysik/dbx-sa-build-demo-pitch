            }],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {
                  "fieldName": "total_watch_minutes",
                  "displayName": "Watch Minutes"
                },
                "color": {
                  "fieldName": "plan_type",
                  "scale": {"type": "categorical"},
