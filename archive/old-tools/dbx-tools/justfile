set shell := ["bash", "-cu"]

dbx_profile TABLE KEYS="" TOP_N="20":
	python dbx_profile.py --table {{TABLE}} --keys "{{KEYS}}" --top-n {{TOP_N}}

dbx_skew TABLE KEYS="" TOP_N="20":
	python3 dbx_skew.py --table {{TABLE}} --keys "{{KEYS}}" --top-n {{TOP_N}}

dbx_plan TABLE:
	python dbx_plan.py --table {{TABLE}}

dbx_delta TABLE:
	python dbx_delta.py --table {{TABLE}}

dbx_files TABLE:
	python dbx_files.py --table {{TABLE}}

dbx_nulls TABLE:
	python dbx_nulls.py --table {{TABLE}}

dbx_keys TABLE KEYS TOP_N="20":
	python dbx_keys.py --table {{TABLE}} --keys "{{KEYS}}" --top-n {{TOP_N}}

dbx_compare LEFT RIGHT KEYS="":
	python dbx_compare.py --left {{LEFT}} --right {{RIGHT}} --keys "{{KEYS}}"
