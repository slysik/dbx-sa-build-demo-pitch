{
  "env": {
    "ANTHROPIC_MODEL": "databricks-claude-opus-4-6",
    "ANTHROPIC_BASE_URL": "https://adb-7405613453749188.8.azuredatabricks.net/serving-endpoints/anthropic",
    "ANTHROPIC_AUTH": "REDACTED_ANTHROPIC_API_KEY",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "databricks-claude-opus-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "databricks-claude-sonnet-4-6",
    "ANTHROPIC_CUSTOM_HEADERS": "x-databricks-disable-beta-headers: true"
  },
  "model": "databricks-claude-opus-4-6",
  "permissions": {
    "allow": [
      "mcp__databricks__execute_sql",
      "mcp__databricks__manage_uc_objects",
      "mcp__databricks__execute_sql_multi",
      "mcp__databricks__get_best_warehouse",
      "mcp__databricks__create_or_update_dashboard",
      "mcp__databricks__upload_file",
      "mcp__databricks__get_best_cluster",
      "mcp__databricks__list_clusters",
      "mcp__databricks__start_cluster",
      "mcp__databricks__get_cluster_status",
      "mcp__databricks__execute_databricks_command",
      "mcp__databricks__get_dashboard"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "databricks"
  ]
}
